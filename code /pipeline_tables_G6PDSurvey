  est <- tryCatch(svyciprop(f, design, na.rm = TRUE), error = function(e) NULL)
  if (is.null(est) || as.numeric(est) == 0) return("NA")
  ci <- attr(est, "ci")
  paste0(
    sprintf("%.1f%%", as.numeric(est) * 100), " (",
    sprintf("%.1f", ci[1] * 100), "\u2013",
    sprintf("%.1f", ci[2] * 100), "%)"
  )
}

# One cell: prevalence of pcr_vals within a single FI5457 level — unweighted
cell_prev_s3 <- function(data, fi5457_val, pcr_vals) {
  sub <- data %>% filter(FI5457 == fi5457_val)
  fmt_prev_s3(sub$PCR_final %in% pcr_vals, nrow(sub))
}

# One cell: prevalence of pcr_vals within a single FI5457 level — weighted
cell_svy_s3 <- function(design, fi5457_val, pcr_vals) {
  sub <- subset(design, FI5457 == fi5457_val)
  fmt_svy_prev_s3(sub,
    paste0("~PCR_final %in% c(", paste(pcr_vals, collapse = ","), ")"))
}

