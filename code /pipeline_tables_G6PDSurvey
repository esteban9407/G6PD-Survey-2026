# --- Helper functions ---

# Median [IQR] — unweighted
fmt_median_iqr <- function(x) {
  x <- x[!is.na(x)]
  paste0(
    sprintf("%.2f", median(x)), " [",
    sprintf("%.2f", quantile(x, 0.25)), ", ",
    sprintf("%.2f", quantile(x, 0.75)), "]"
  )
}

# Median [IQR] — weighted
fmt_svy_median_iqr <- function(design, var) {
  q    <- svyquantile(as.formula(paste0("~", var)),
                      design, quantiles = c(0.25, 0.5, 0.75), na.rm = TRUE)
  vals <- as.numeric(q[[1]])
  paste0(
    sprintf("%.2f", vals[2]), " [",
    sprintf("%.2f", vals[1]), ", ",
    sprintf("%.2f", vals[3]), "]"
  )
}

# Prevalence % [95% CI] — unweighted
fmt_prev_t2 <- function(x_logical, n_total) {
  n_pos <- sum(x_logical, na.rm = TRUE)
  if (n_pos == 0 || n_total == 0) return("NA")
  pt <- prop.test(n_pos, n_total)
  paste0(
    sprintf("%.1f%%", n_pos / n_total * 100), " [",
    sprintf("%.1f", pt$conf.int[1] * 100), "–",
    sprintf("%.1f", pt$conf.int[2] * 100), "]"
  )
}

# Prevalence % [95% CI] — weighted
fmt_svy_prev_t2 <- function(design, formula_str) {
  f   <- as.formula(formula_str)
  est <- svyciprop(f, design, na.rm = TRUE)
  ci  <- attr(est, "ci")
  if (as.numeric(est) == 0) return("NA")
  paste0(
    sprintf("%.1f%%", as.numeric(est) * 100), " [",
    sprintf("%.1f", ci[1] * 100), "–",
    sprintf("%.1f", ci[2] * 100), "]"
  )
}

