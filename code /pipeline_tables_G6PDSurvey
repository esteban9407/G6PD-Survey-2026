# --- Helper functions ---

# n (%) — denominator: non-missing in var_name
pct_row <- function(data, var_name, vals, label) {
  data %>%
    group_by(grupo, .drop = FALSE) %>%
    summarise(
      n_match = sum(.data[[var_name]] %in% vals, na.rm = TRUE),
      n_denom = sum(!is.na(.data[[var_name]])),
      .groups = "drop"
    ) %>%
    mutate(val = paste0(n_match, " (", round(n_match / n_denom * 100, 1), "%)")) %>%
    select(grupo, val) %>%
    pivot_wider(names_from = grupo, values_from = val) %>%
    mutate(Variable = label) %>%
    select(Variable, everything())
}

# n (%) — denominator: total group n (includes NA rows, for PCR section)
pct_row_total <- function(data, var_name, vals, label) {
  data %>%
    group_by(grupo, .drop = FALSE) %>%
    summarise(
      n_match = sum(.data[[var_name]] %in% vals, na.rm = TRUE),
      n_denom = n(),
      .groups = "drop"
    ) %>%
    mutate(val = paste0(n_match, " (", round(n_match / n_denom * 100, 1), "%)")) %>%
    select(grupo, val) %>%
    pivot_wider(names_from = grupo, values_from = val) %>%
    mutate(Variable = label) %>%
    select(Variable, everything())
}

# n (%) — denominator: custom subset of PCR_final values
pct_row_denom <- function(data, var_name, vals, denom_vals, label) {
  data %>%
    group_by(grupo, .drop = FALSE) %>%
    summarise(
      n_match = sum(.data[[var_name]] %in% vals, na.rm = TRUE),
      n_denom = sum(.data[[var_name]] %in% denom_vals, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    mutate(val = ifelse(n_denom == 0, "NA",
      paste0(n_match, " (", round(n_match / n_denom * 100, 1), "%)"))) %>%
    select(grupo, val) %>%
    pivot_wider(names_from = grupo, values_from = val) %>%
    mutate(Variable = label) %>%
    select(Variable, everything())
}

# n (%) of NA rows
na_row <- function(data, var_name, label) {
  data %>%
    group_by(grupo, .drop = FALSE) %>%
    summarise(
      n_match = sum(is.na(.data[[var_name]])),
      n_denom = n(),
      .groups = "drop"
    ) %>%
    mutate(val = paste0(n_match, " (", round(n_match / n_denom * 100, 1), "%)")) %>%
    select(grupo, val) %>%
    pivot_wider(names_from = grupo, values_from = val) %>%
    mutate(Variable = label) %>%
    select(Variable, everything())
}

# mean (SD) for a continuous variable
mean_sd_row <- function(data, var_name, label) {
  data %>%
    group_by(grupo, .drop = FALSE) %>%
    summarise(
      val = paste0(
        round(mean(.data[[var_name]], na.rm = TRUE), 1),
        " (", round(sd(.data[[var_name]], na.rm = TRUE), 1), ")"
      ),
      .groups = "drop"
    ) %>%
    pivot_wider(names_from = grupo, values_from = val) %>%
    mutate(Variable = label) %>%
    select(Variable, everything())
}

