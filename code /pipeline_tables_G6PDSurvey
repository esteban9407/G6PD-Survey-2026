# --- Helpers: extract PR + profile-likelihood CI 95%, formatted to 2 decimals ---
# Returns c(pr = "", ci = "") when the term is absent or not estimable, so the
# corresponding Excel cell is left blank rather than showing "NA".
#
# CI method: profile likelihood via confint() (dispatches to MASS::confint.glm).
# CONFIRMED EMPIRICALLY against your own R session: for g3_hist_crude /
# g3_hist_adj, confint() reproduced the original .qmd values exactly
# (0.44-1.82 and 0.46-1.99), while Wald variants did not. Profile likelihood
# is the correct method here.

extract_glm_pr <- function(model, term_pattern) {
  est <- coef(model)
  idx <- grep(term_pattern, names(est), ignore.case = TRUE)
  if (length(idx) == 0 || is.na(est[idx[1]])) return(c(pr = "", ci = ""))
  i <- idx[1]
  term_name <- names(est)[i]

  ci <- tryCatch(
    suppressMessages(confint(model, parm = term_name)),
    error = function(e) {
      message("extract_glm_pr(): profile-likelihood CI failed for term '", term_name,
              "' \u2013 returning blank CI. Error: ", conditionMessage(e))
      NULL
    },
    warning = function(w) {
      message("extract_glm_pr(): profile-likelihood CI raised a warning for term '",
              term_name, "' \u2013 ", conditionMessage(w),
              ". Proceeding with the profiled result; please check this term manually.")
      suppressWarnings(suppressMessages(confint(model, parm = term_name)))
    }
  )
  if (is.null(ci)) return(c(pr = sprintf("%.2f", exp(est[i])), ci = ""))

  # confint(model, parm=<one term>) returns a plain 2-element vector (not a
  # matrix), unlike confint(model) on the whole model -- index accordingly.
  c(pr = sprintf("%.2f", exp(est[i])),
    ci = sprintf("%.2f \u2013 %.2f", exp(ci[1]), exp(ci[2])))
}

# See CAVEAT in the section header comment above.
extract_gee_pr <- function(model, term_pattern) {
  s <- summary(model)
  coefs <- if (!is.null(s$coefficients)) s$coefficients else s$coef
  if (is.null(coefs)) {
    warning("extract_gee_pr(): no $coefficients found in summary(model).")
    return(c(pr = "", ci = ""))
  }
  idx <- grep(term_pattern, rownames(coefs), ignore.case = TRUE)
  if (length(idx) == 0) return(c(pr = "", ci = ""))
  se_col <- grep("robust|std|se", colnames(coefs), ignore.case = TRUE)[1]
  if (is.na(se_col)) {
    warning("extract_gee_pr(): no standard-error column found in summary(model)$coefficients. ",
            "Columns available: ", paste(colnames(coefs), collapse = ", "))
    return(c(pr = "", ci = ""))
  }
  i <- idx[1]
  est <- coefs[i, 1]
  se  <- coefs[i, se_col]
  if (is.na(est) || is.na(se)) return(c(pr = "", ci = ""))
  c(pr = sprintf("%.2f", exp(est)),
    ci = sprintf("%.2f \u2013 %.2f", exp(est - 1.96 * se), exp(est + 1.96 * se)))
}

