  s4_g1$logg6pd <- log(s4_g1$FI5356)

  s4_g3 <- g3_t3
  s4_g3$logg6pd <- log(s4_g3$FI5356)

  s4_g4 <- g4_t3
  s4_g4$logg6pd <- log(s4_g4$FI5356)

  n_s4_g1 <- nrow(s4_g1)
  n_s4_g3 <- nrow(s4_g3)
  n_s4_g4 <- nrow(s4_g4)

  # Species factor for Group 1 in S4 — includes P. vivax (see header note)
  s4_g1_sp <- s4_g1
  s4_g1_sp$species <- factor(
    ifelse(s4_g1_sp$PCR_final == 1, 0,
    ifelse(s4_g1_sp$PCR_final == 4, 1,
    ifelse(s4_g1_sp$PCR_final == 5, 2, 3))),
    levels = c(0, 1, 2, 3), labels = c("Negative", "P falciparum", "P vivax", "Others")
  )
  
}

# --- Models: Group 1 (GEE) ---
{
  s4_g1_base <- geelm(logg6pd ~ ethnicity_binary + male + history_malaria + pcr06,
                       data = s4_g1, id = cod_viv,
                       family = gaussian(), corstr = "exchangeable", weights = weight)
  s4_g1_sp_m <- geelm(logg6pd ~ ethnicity_binary + male + history_malaria + species,
                       data = s4_g1_sp, id = cod_viv,
                       family = gaussian(), corstr = "exchangeable", weights = weight)
}

# --- Models: Group 3 (Outpatients, glm) ---

{
  s4_g3_base <- glm(logg6pd ~ ethnicity_binary + male + history_malaria + pcr06,
                     data = s4_g3, family = gaussian())
  s4_g3_sp_m <- glm(logg6pd ~ male + history_malaria + species,
                     data = s4_g3, family = gaussian())
}

# --- Models: Group 4 (restricted to Afro-Colombians, glm, no ethnicity term) ---
{
  s4_g4_base <- glm(logg6pd ~ male + history_malaria + pcr06,
                     data = s4_g4, family = gaussian())
  s4_g4_sp_m <- glm(logg6pd ~ male + history_malaria + species,
                     data = s4_g4, family = gaussian())
}

# --- Column names ---
{
  col_s4_g1    <- "v_g1_est"
  col_s4_g1_ci <- "v_g1_ci"
  col_s4_g3    <- "v_g3_est"
  col_s4_g3_ci <- "v_g3_ci"
  col_s4_g4    <- "v_g4_est"
  col_s4_g4_ci <- "v_g4_ci"

  # Descriptive group headers, built to match the published S4 Table wording
  # exactly (used only at export time, in the merged header row below).
  hdr_s4_g1 <- paste0("exp(\u03b2) adjusted (general population, group 1, n=", n_s4_g1, ")")
  hdr_s4_g3 <- paste0("exp(\u03b2) adjusted (Outpatients with suspected malaria, group 3, n=", n_s4_g3, ")")
  hdr_s4_g4 <- paste0("exp(\u03b2) adjusted (Outpatients with suspected malaria restricted to Afro-Colombians, n=", n_s4_g4, ")")
}

make_row_s4 <- function(label, g1, g3, g4) {
  tibble(
    Variable = label,
    !!col_s4_g1    := unname(g1["pr"]), !!col_s4_g1_ci := unname(g1["ci"]),
    !!col_s4_g3    := unname(g3["pr"]), !!col_s4_g3_ci := unname(g3["ci"]),
    !!col_s4_g4    := unname(g4["pr"]), !!col_s4_g4_ci := unname(g4["ci"])
  )
}

# --- Build rows ---
{
  rows_s4 <- bind_rows(

    make_row_s4("Afro-Colombian",
      extract_gee_pr(s4_g1_base, "ethnicity_binary"),
      extract_glm_pr(s4_g3_base, "ethnicity_binary"),
      empty_pr_ci),

    make_row_s4("Male",
      extract_gee_pr(s4_g1_base, "^male$"),
      extract_glm_pr(s4_g3_base, "^male$"),
      extract_glm_pr(s4_g4_base, "^male$")),

    make_row_s4("Prior reported history of malaria",
      extract_gee_pr(s4_g1_base, "history_malaria"),
      extract_glm_pr(s4_g3_base, "history_malaria"),
      extract_glm_pr(s4_g4_base, "history_malaria")),

    make_row_s4("Current Plasmodium infection, any species",
      extract_gee_pr(s4_g1_base, "pcr06"),
      extract_glm_pr(s4_g3_base, "pcr06"),
      extract_glm_pr(s4_g4_base, "pcr06")),

    make_row_s4("   P. falciparum",
      extract_gee_pr(s4_g1_sp_m, "falciparum"),
      extract_glm_pr(s4_g3_sp_m, "falciparum"),
      extract_glm_pr(s4_g4_sp_m, "falciparum")),

    make_row_s4("   P. vivax",
      extract_gee_pr(s4_g1_sp_m, "vivax"),
      extract_glm_pr(s4_g3_sp_m, "vivax"),
      extract_glm_pr(s4_g4_sp_m, "vivax")),

    make_row_s4("   Others",
      extract_gee_pr(s4_g1_sp_m, "Others"),
      extract_glm_pr(s4_g3_sp_m, "Others"),
      extract_glm_pr(s4_g4_sp_m, "Others"))
  )
}

# --- Export ---
{
  wb <- createWorkbook()
  addWorksheet(wb, "S4 Table")

  writeData(wb, "S4 Table",
    "S4 Table. Associations between sex, ethnicity, malaria, and the level of G6PD enzymatic activity (IIU/g Hb), study population.",
    startRow = 1, startCol = 1)
  mergeCells(wb, "S4 Table", cols = 1:7, rows = 1)
  addStyle(wb, "S4 Table",
    createStyle(fontSize = 11, fontName = "Arial", textDecoration = "bold", wrapText = TRUE),
    rows = 1, cols = 1)
  setRowHeights(wb, "S4 Table", rows = 1, heights = 30)

  # --- 2-row merged header, matching the published S4 Table layout ---
  # Row 3: descriptive group header (merged over its Estimates/CI 95% pair).
  # Row 4: "Factors" (merged vertically) / "Estimates" / "CI 95%" per group.
  header_row_group <- 3
  header_row_sub   <- 4
  data_start_row   <- 5

  writeData(wb, "S4 Table", "Factors", startRow = header_row_group, startCol = 1)
  mergeCells(wb, "S4 Table", cols = 1, rows = header_row_group:header_row_sub)

  writeData(wb, "S4 Table", hdr_s4_g1, startRow = header_row_group, startCol = 2)
  writeData(wb, "S4 Table", hdr_s4_g3, startRow = header_row_group, startCol = 4)
  writeData(wb, "S4 Table", hdr_s4_g4, startRow = header_row_group, startCol = 6)
  mergeCells(wb, "S4 Table", cols = 2:3, rows = header_row_group)
  mergeCells(wb, "S4 Table", cols = 4:5, rows = header_row_group)
  mergeCells(wb, "S4 Table", cols = 6:7, rows = header_row_group)

  writeData(wb, "S4 Table",
    t(rep(c("Estimates", "CI 95%"), 3)),
    startRow = header_row_sub, startCol = 2, colNames = FALSE)

  writeData(wb, "S4 Table", rows_s4, startRow = data_start_row, startCol = 1, colNames = FALSE)

  addStyle(wb, "S4 Table",
    createStyle(fontSize = 9, fontName = "Arial", textDecoration = "bold",
                halign = "center", valign = "center", border = "TopBottom", wrapText = TRUE),
    rows = header_row_group:header_row_sub, cols = 1:7, gridExpand = TRUE)
  setRowHeights(wb, "S4 Table", rows = header_row_group:header_row_sub, heights = 30)

  addStyle(wb, "S4 Table",
    createStyle(fontSize = 9, fontName = "Arial", wrapText = TRUE),
    rows = data_start_row:(data_start_row + nrow(rows_s4) - 1), cols = 1:7, gridExpand = TRUE)

  setColWidths(wb, "S4 Table", cols = 1,    widths = 45)
  setColWidths(wb, "S4 Table", cols = 2:7,  widths = 18)
  freezePane(wb, "S4 Table", firstActiveRow = data_start_row, firstActiveCol = 2)

  fn_row <- data_start_row + nrow(rows_s4) + 1
  writeData(wb, "S4 Table",
    "*Adjusted by ethnic group, sex and prior history of malaria.",
    startRow = fn_row, startCol = 1)
  addStyle(wb, "S4 Table",
    createStyle(fontSize = 8, fontName = "Arial", fontColour = "#555555"),
    rows = fn_row, cols = 1)

  saveWorkbook(wb, "TableS4_G6PD_2026.xlsx", overwrite = TRUE)
  message("TableS4_G6PD_2026.xlsx saved")
}
