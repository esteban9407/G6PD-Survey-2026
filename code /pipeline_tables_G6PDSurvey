# ==============================================================================
# SECTION 1 — Data preparation
# ------------------------------------------------------------------------------
# Source  : bd_G6PDSurvey_2026 (exclusions already applied)
# Action  : Replace sentinel missing values (−999, −9999, 999) with NA.
#           A single working copy (df) is used throughout the entire script.
# ==============================================================================
# DATA DICTIONARY — variables used across all tables
# ------------------------------------------------------------------------------
# id_compuesto : Participant unique ID
# lugar        : Recruitment site  | 1 = General population
#                                  | 2 = Outpatients
#                                  | 3 = Indigenous
# sex          : Biological sex    | 1 = Female  | 2 = Male
# etnia        : Ethnicity         | 1 = Afro-Colombian | 2 = Indigenous | 3 = Other
# edad         : Age in years (continuous)
# edadhemo     : Age group | 1 = 5–11 years | 2 = 12–14 years | 3 = ≥15 years
# FI0005       : Consanguinity between parents | 1 = Yes | 2 = No
# FI0015       : Years of residence (continuous)
# FI0015cd     : Years of residence (binary) | 0 = <5 years | 1 = ≥5 years
# FI0017       : Overnight absence last 3 months | 1 = Yes | 2 = No
# FI0021       : Malaria transmission in place visited | 1 = Yes | 2 = No | 3 = DK
# FI0022       : Ethnicity (self-report 5-cat) | 1=Mestizo | 2=Afro | 3=White
#                                              | 4=Indigenous | 5=Other
# FI0023       : Prior diagnosis of G6PD deficiency | 1 = Yes
# FI0024       : Prior diagnosis of hemolytic anemia | 1 = Yes
# FI0030       : Hospitalized due to hemolytic event | 1 = Yes (if FI0024==1)
# FI0031       : Prior blood transfusion | 1 = Yes
# FI0035       : Previous malaria diagnosis | 1 = Yes | 2 = No | 3 = DK
# FI0036       : Lifetime malaria episodes (continuous)
# FI0037       : Time since last episode | 1–3 = <6 months | 4–5 = ≥6 months
#                                        | 6 = Does not remember
# FI0040       : PQ intake with last malaria episode | 1 = Yes
# FI0041       : Adverse event to PQ | 1 = Yes (if FI0040==1)
# FI0042       : Adverse event symptom (free text)
# FI0046       : Fever last 3 days | 1 = Yes | 2 = No
# FI0080       : Binary G6PD | 0 = Normal/Intermediate | 1 = Deficient
# FI0081       : Binary G6PD | 0 = Normal | 1 = Deficient/Intermediate
# FI5356       : Final G6PD enzyme activity (UI/gHb) — continuous
# FI5457       : G6PD interpretation | 1 = Normal | 2 = Intermediate | 3 = Deficient
# FI5558       : Hemoglobin final value (g/dL)
# MAH          : WHO classification | 1 = <30% | 2 = 30–70% | 3 = >70%
# PCR06r       : Malaria result (binary) | 0 = Negative | 1 = Positive
# PCR_final    : Final molecular diagnosis
#                  1 = Negative | 2 = Species not identified | 3 = Mixed
#                  4 = P. falciparum | 5 = P. vivax
# weight       : Sampling weight (Group 1 only)
# comuna/barrio: Used to build PSU (Group 1 only)
# cod_viv      : Household cluster ID (GEE only)
# ------------------------------------------------------------------------------

{
  df <- bd_G6PDSurvey_2026

  # Replace all sentinel missing values with NA
  df[df == -999 | df == -9999 | df == 999] <- NA

  # df_full: sentinel-cleaned data BEFORE participant exclusion.
  # Used only by Table 1, which reports the total study population.
  df_full <- df

  # Participant exclusion -- applies to Table 2, S1-S4 Tables, and Table 3.
  # Table 1 is the exception: it uses df_full (total, unexcluded) above.
  exclude_ids <- c("10112701", "800127", "800032", "50214001",
                   "9051803", "10333502", "50104501", "700219")
  df$id_compuesto_chr <- trimws(as.character(df$id_compuesto))
  df <- df[!df$id_compuesto_chr %in% exclude_ids, ]
}

# ==============================================================================
# SECTION 2 — Shared survey infrastructure (Groups 1–4)
# ------------------------------------------------------------------------------
# Group 1: General population (lugar == 1) — complex survey design with weights
# Group 2: Indigenous (lugar == 3)         — no weights
# Group 3: Outpatients (lugar == 2)        — no weights
# Group 4: Outpatients Afro-Colombian only (lugar == 2, etnia == 1) — no weights
# PSU and FPC are used only for Group 1.
# ==============================================================================
{
  # Build PSU identifier
  df <- df %>%
    mutate(
      psu = paste0(comuna, "0", barrio),
      psu = ifelse(comuna == 10, paste0(comuna, barrio), psu)
    )

  # Finite population correction table (Group 1 only)
  fpcprevalence <- data.frame(
    psu    = c("1002","1003","1004","1005","1006","1007","1008",
               "101","102","103","104","105","106",
               "202","301","501","502","503","604","601","603"),
    fcpval = c(36,45,14,79,91,477,172,
               225,217,434,369,453,366,
               310,328,99,462,37,113,161,28)
  )
}

