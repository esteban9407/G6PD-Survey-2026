{
  df_t1 <- df_full  # Table 1 reports the TOTAL study population (no exclusion)

  # Impute ethnicity for Indigenous community participants (by design, all are Indigenous)
  df_t1$etnia[df_t1$lugar == 3 & is.na(df_t1$etnia)] <- 3L

  df_t1 <- df_t1 %>% filter(lugar %in% c(1, 2, 3))

  # BUGFIX
  n1 <- nrow(df_t1 %>% filter(lugar == 1))
  n2 <- nrow(df_t1 %>% filter(lugar == 3))
  n3 <- nrow(df_t1 %>% filter(lugar == 2))

  col_g1 <- paste0("General population (Group 1) (n=", n1, ")")
  col_g2 <- paste0("Indigenous (Group 2) (n=",         n2, ")")
  col_g3 <- paste0("Outpatients (Group 3) (n=",        n3, ")")

  # Main dataset with group factor in display order: Group 1 / Group 2 / Group 3
  df_t1 <- df_t1 %>%
    mutate(grupo = factor(lugar,
      levels = c(1, 3, 2),
      labels = c(col_g1, col_g2, col_g3)
