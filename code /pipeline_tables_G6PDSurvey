# --- Helper functions ---

fmt_prev_s1 <- function(x_logical, n_total) {
  n_pos <- sum(x_logical, na.rm = TRUE)
  if (n_pos == 0 || n_total == 0 || all(is.na(x_logical))) return("NA")
  pt <- prop.test(n_pos, n_total)
  paste0(
    sprintf("%.1f%%", n_pos / n_total * 100), " (",
    sprintf("%.1f", pt$conf.int[1] * 100), "\u2013",
    sprintf("%.1f", pt$conf.int[2] * 100), "%)"
  )
}

fmt_svy_prev_s1 <- function(design, formula_str) {
  f   <- as.formula(formula_str)
  est <- tryCatch(svyciprop(f, design, na.rm = TRUE), error = function(e) NULL)
  if (is.null(est) || as.numeric(est) == 0) return("NA")
  ci <- attr(est, "ci")
  paste0(
    sprintf("%.1f%%", as.numeric(est) * 100), " (",
    sprintf("%.1f", ci[1] * 100), "\u2013",
    sprintf("%.1f", ci[2] * 100), "%)"
  )
}

make_row_s1 <- function(label, g1_val, g2_val, g3_val) {
