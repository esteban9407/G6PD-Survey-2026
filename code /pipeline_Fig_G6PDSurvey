# Helper: builds the legend label vector for a given subset.
# Returns a named character vector: names = sex codes, values = "Female (n = X)"
build_legend <- function(data, lugar_code = NULL, etnia_code = NULL) {
  d <- data
  if (!is.null(lugar_code)) d <- dplyr::filter(d, lugar == lugar_code)
  if (!is.null(etnia_code)) d <- dplyr::filter(d, etnia == etnia_code)

  totales <- d %>%
    dplyr::filter(!is.na(FI5356)) %>%
    dplyr::count(sex) %>%
    dplyr::mutate(label = dplyr::case_when(
      sex == 1 ~ paste0("Female (n = ", n, ")"),
      sex == 2 ~ paste0("Male (n = ", n, ")")
    ))

  lbl <- totales$label
  names(lbl) <- as.character(totales$sex)
  lbl
}

# Shared theme — PLOS font size requirements: 8–12 pt
theme_plos <- theme_classic() +
  theme(
    legend.position      = c(0.8, 0.9),
    legend.direction     = "vertical",
    legend.justification = "center",
    legend.background    = element_rect(fill = "transparent"),
    legend.key.size      = unit(1.2, "lines"),
    legend.text          = element_text(size = 9),
    axis.text.x          = element_text(size = 8),
    axis.text.y          = element_text(size = 8),
    axis.title.y         = element_text(size = 9),
    axis.title.x         = element_text(size = 9)
  )

# Color palette — Female = red (#BA0C2F), Male = blue (#0067B9)
# Keyed to character "1" / "2" (factor levels of sex)
pal_fill  <- c("1" = "#BA0C2F", "2" = "#0067B9")
pal_color <- c("1" = "#BA0C2F", "2" = "#0067B9")


