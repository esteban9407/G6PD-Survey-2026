# ==============================================================================
# SECTION 1 — Data preparation
# ------------------------------------------------------------------------------
# Source  : bd_G6PDSurvey_2026 (raw, as loaded -- NOT pre-excluded)
# Action  : Replace sentinel missing values (-999, -9999, 999) with NA, then
#           apply the 8-ID participant exclusion used throughout the rest of
#           this analysis (same exclusion as pipeline_tables_2.R Section 1).
#
#           TWO working copies are used:
#             - `df`      : sentinel-NA replaced + 8-ID exclusion applied.
#                           Used by Fig 3 (Section 3), Fig 4, Fig 5 (Section 5), S2 Fig.
#             - `df_full` : sentinel-NA replaced ONLY, NO exclusion applied.
#                           Used ONLY by S1 Fig (Bland-Altman, Section 7).
# ==============================================================================

# DATA DICTIONARY — variables used across all figures
# ------------------------------------------------------------------------------
# id_compuesto : Participant unique ID
# lugar        : Recruitment site  | 1 = Urban neighborhood/district of Quibdó
#                                  | 2 = Malaria diagnostic post
#                                  | 3 = Indigenous community
# sex          : Biological sex    | 1 = Female  | 2 = Male
# etnia        : Ethnicity         | 1 = Afro-Colombian | 2 = Indigenous | 3 = Other
# FI5356       : Final G6PD enzyme activity (UI/gHb) — continuous
# FI5457       : G6PD interpretation | 1 = Normal | 2 = Intermediate | 3 = Deficient
# FI0053       : G6PD enzyme activity — first measurement (UI/gHb)
# FI0055       : Hemoglobin — first measurement (g/dL)
# FI5558       : Hemoglobin — final value (g/dL)
# PCR06r       : Malaria result (binary) | 0 = Negative | 1 = Positive
# PCR_final    : Final molecular diagnosis
#                  1 = Negative for genus | 2 = Species not identified
#                  3 = Mixed infection    | 4 = P. falciparum | 5 = P. vivax
# ------------------------------------------------------------------------------

{
  df <- bd_G6PDSurvey_2026

  # Replace all sentinel missing values with NA
  df[df == -999 | df == -9999 | df == 999] <- NA

  # `df_full`: same sentinel-NA cleanup, but WITHOUT the 8-ID exclusion below.
  # Used only by S1 Fig (Bland-Altman, Section 7) -- see note above.
  df_full <- df

  # Participant exclusion -- applies to `df` (all figures except Bland-Altman).
  # Same 8 IDs excluded in pipeline_tables_2.R Section 1.
  exclude_ids <- c("10112701", "800127", "800032", "50214001",
                   "9051803", "10333502", "50104501", "700219")
  df$id_compuesto_chr <- trimws(as.character(df$id_compuesto))
  df <- df[!df$id_compuesto_chr %in% exclude_ids, ]
}


