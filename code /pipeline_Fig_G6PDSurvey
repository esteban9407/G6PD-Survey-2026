# ==============================================================================
# SECTION 5 — Figure 5: malaria prevalence by G6PD status
# ------------------------------------------------------------------------------
# Restricted to General population (lugar == 1) and Outpatients (lugar == 2).
# Mixed infections and unidentified species excluded (PCR_final %in% c(2, 3)).
# Proportion = cases per PCR_final / total per lugar × FI5457 group.
# ==============================================================================

{
  # Base dataset: two sites, non-missing enzyme activity
  df_fig5 <- df %>%
    filter(!is.na(FI5356), lugar %in% c(1, 2)) %>%
    mutate(
      lugar  = factor(lugar,
                      levels = c(1, 2),
                      labels = c("General population", "Outpatients")),
      FI5457 = factor(FI5457,
                      levels = c(3, 2, 1),
                      labels = c("Deficient", "Intermediate", "Normal"))
    )

  # Case count per PCR_final category within each lugar × FI5457 group
  casos_virus <- df_fig5 %>%
    filter(!is.na(PCR_final), PCR_final %in% c(1, 4, 5)) %>%
    mutate(PCR_final = factor(PCR_final,
                              levels = c(1, 5, 4),
                              labels = c("No malaria", "P. vivax", "P. falciparum"))) %>%
    group_by(lugar, FI5457, PCR_final) %>%
    summarise(casos_virus = n(), .groups = "drop")

  # Total cases per lugar × FI5457 group (denominator)
  total_por_grupo <- df_fig5 %>%
    group_by(lugar, FI5457) %>%
    summarise(total_casos = n(), .groups = "drop")

  # Prevalence = cases / total per group
  prevalencia <- casos_virus %>%
    left_join(total_por_grupo, by = c("lugar", "FI5457")) %>%
    mutate(prevalencia = casos_virus / total_casos)
}

{
  grap11 <- ggplot(prevalencia,
                   aes(x = PCR_final, y = prevalencia, fill = PCR_final)) +
    geom_col() +
    geom_text(
      aes(label = paste0("n=", casos_virus, "\n", round(prevalencia * 100, 1), "%")),
      vjust = -0.3,
      size  = 2.5
    ) +
    facet_grid(lugar ~ FI5457) +
    scale_fill_manual(
      values = c("No malaria"    = "darkgray",
                 "P. vivax"      = "darkgreen",
                 "P. falciparum" = "#0067B9")
    ) +
    scale_y_continuous(expand = expansion(mult = c(0, 0.22))) +
    labs(y = "Proportion (%)", x = "Species", fill = NULL) +
    theme_classic() +
    theme(
      axis.text.x          = element_blank(),
      axis.ticks.x         = element_blank(),
      axis.text.y          = element_text(size = 8),
      axis.title.y         = element_text(size = 9),
      axis.title.x         = element_text(size = 9),
      legend.position      = "right",
      legend.direction     = "vertical",
      legend.justification = "center",
      legend.background    = element_rect(fill = "transparent"),
      legend.key.size      = unit(1.2, "lines"),
      legend.text          = element_text(size = 8),
      strip.text           = element_text(size = 8)
    )

  ggsave(
    filename    = "Fig5.tif",
    plot        = grap11,
    width       = 17.4,
    height      = 12.0,
    units       = "cm",
