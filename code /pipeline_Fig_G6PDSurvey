# ==============================================================================
# SECTION 7 — S1 Fig: Bland-Altman agreement plots
# ------------------------------------------------------------------------------
# Panel A: G6PD enzyme activity — first vs. final measurement
# Panel B: Hemoglobin — first vs. final measurement
# Only rows where both measurements exist AND differ are included.
# ==============================================================================

# Helper: compute Bland-Altman summary statistics
ba_limits <- function(data) {
  list(
    bias   = mean(data$diferencia),
    sd     = sd(data$diferencia),
    loa_hi = mean(data$diferencia) + 1.96 * sd(data$diferencia),
    loa_lo = mean(data$diferencia) - 1.96 * sd(data$diferencia)
  )
}

# Helper: build one Bland-Altman panel
make_ba_plot <- function(data, x_label, y_label) {
  lim   <- ba_limits(data)
  y_lo  <- lim$bias - 9.5 * lim$sd
  y_hi  <- lim$bias + 9.5 * lim$sd
  x_ann <- quantile(data$promedio, 0.95, na.rm = TRUE)

  ggplot(data, aes(x = promedio, y = diferencia)) +
    geom_point(pch = 1, size = 1.2, col = "black", alpha = 0.6) +
    geom_smooth(method = "lm", se = TRUE,
                fill = "lightgrey", linewidth = 0.4, linetype = 5) +
    geom_hline(yintercept = lim$bias,   linewidth = 1.0) +
    geom_hline(yintercept = 0,          linetype = 3, col = "grey30") +
    geom_hline(yintercept = lim$loa_hi, linetype = 2, col = "firebrick") +
    geom_hline(yintercept = lim$loa_lo, linetype = 2, col = "firebrick") +
    annotate("text", x = x_ann, y = lim$bias   + 0.3,
             label = "Bias",     size = 2.5, colour = "black",     hjust = 1) +
    annotate("text", x = x_ann, y = lim$loa_hi + 0.3,
             label = "+ 1.96 SD", size = 2.5, colour = "firebrick", hjust = 1) +
    annotate("text", x = x_ann, y = lim$loa_lo - 0.3,
             label = "- 1.96 SD", size = 2.5, colour = "firebrick", hjust = 1) +
    ylim(y_lo, y_hi) +
    labs(x = x_label, y = y_label) +
    theme_bw() +
    theme(
      plot.title       = element_text(hjust = 0.5),
      panel.grid.major = element_blank(),
      panel.grid.minor = element_blank(),
      axis.text.x      = element_text(size = 8),
      axis.text.y      = element_text(size = 8),
      axis.title.x     = element_text(size = 9),
      axis.title.y     = element_text(size = 9)
    )
}

{
  # NOTE: uses `df_full` (NO 8-ID exclusion), unlike every other figure in
  # this script -- see Section 1 header comment for the reason.
  # G6PD dataset
  ba_g6pd <- df_full %>%
    select(FI0053, FI5356) %>%
    filter(complete.cases(.)) %>%
    mutate(
      diferencia = FI0053 - FI5356,
      promedio   = rowMeans(cbind(FI0053, FI5356), na.rm = TRUE)
    ) %>%
    filter(FI0053 != FI5356)

  # Hemoglobin dataset
  ba_hemo <- df_full %>%
    select(FI0055, FI5558) %>%
    filter(complete.cases(.)) %>%
    mutate(
      diferencia = FI0055 - FI5558,
      promedio   = rowMeans(cbind(FI0055, FI5558), na.rm = TRUE)
    ) %>%
    filter(FI0055 != FI5558)

  plot_g6pd <- make_ba_plot(ba_g6pd,
                             x_label = "Mean G6PD (UI/gHb)",
                             y_label = "Difference G6PD (UI/gHb)")

  plot_hemo <- make_ba_plot(ba_hemo,
                             x_label = "Mean Hb (g/dL)",
                             y_label = "Difference Hb (g/dL)")

  composicion_ba <- plot_grid(
    plot_g6pd, plot_hemo,
    ncol       = 2,
    labels     = c("A", "B"),
    align      = "h",
    rel_widths = c(1, 1)
  )

  ggsave(
    filename    = "FigS1.tif",
    plot        = composicion_ba,
    width       = 17.4,
    height      = 9.0,
    units       = "cm",
    dpi         = 300,
    compression = "lzw",
    device      = "tiff"
  )

  message("FigS1.tif exported — 17.4 x 9.0 cm, 300 dpi, LZW compression")
}

