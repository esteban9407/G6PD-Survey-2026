# ==============================================================================
# SECTION 4 — Figure 4: G6PD enzyme activity by malaria status and site
# ------------------------------------------------------------------------------
# Builds a four-group dataset combining all three recruitment sites plus an
# Afro-Colombian-only subset from the diagnostic post.
# Panel A (grap6)  : boxplot + jitter by binary malaria result (PCR06r)
# Panel B (grap10) : boxplot + jitter by final molecular diagnosis (PCR_final)
# ==============================================================================

{
  # All three recruitment sites (lugar: 1, 2, 3)
  ar <- df %>%
    select(id_compuesto, lugar, PCR06r, FI5356, FI5457, PCR_final) %>%
    filter(!is.na(PCR06r), !is.na(FI5356))

  # Afro-Colombian subset from the diagnostic post (lugar == 2, etnia == 1)
  # Assigned a temporary numeric code 4 to distinguish from the full Outpatients group
  acd <- df %>%
    select(id_compuesto, etnia, PCR06r, FI5356, FI5457, lugar, PCR_final) %>%
    filter(!is.na(PCR06r), !is.na(FI5356), lugar == 2, etnia == 1) %>%
    select(-lugar) %>%
    rename(lugar = etnia) %>%
    mutate(lugar = 4)

  # Stack and assign English labels via numeric factor levels
  df_fig4 <- rbind(ar, acd) %>%
    mutate(
      lugar  = factor(lugar,
                      levels = c(1, 3, 2, 4),
                      labels = c("General population",
                                 "Indigenous",
                                 "Outpatients",
                                 "Outpatients restricted to Afro-Colombians")),
      PCR06r = factor(PCR06r,
                      levels = c(0, 1),
                      labels = c("Malaria negative", "Malaria positive"))
    )

  # Subset for panel B: keep only PCR_final 1 (negative), 4 (P. falciparum), 5 (P. vivax)
  # Excludes mixed infections (3) and unidentified species (2)
  df_fig4b <- df_fig4 %>%
    filter(PCR_final %in% c(1, 4, 5)) %>%
    mutate(PCR_final = factor(PCR_final,
                              levels = c(1, 5, 4),
                              labels = c("No malaria", "P. vivax only", "P. falciparum only")))
}

